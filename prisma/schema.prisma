generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth required tables) ─────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invite {
  id        String    @id @default(cuid())
  email     String    @unique
  role      UserRole  @default(REVGEN)
  invitedBy String
  createdAt DateTime  @default(now())
  usedAt    DateTime?
}

// ─── Users ────────────────────────────────────────────────────────────────────

enum UserRole {
  FINANCE
  LEADERSHIP
  REVGEN
}

model User {
  id             String               @id @default(cuid())
  email          String               @unique
  name           String?
  image          String?
  role           UserRole             @default(REVGEN)
  emailVerified  DateTime?
  createdAt      DateTime             @default(now())
  accounts                Account[]
  sessions                Session[]
  auditLogs               AuditLog[]
  revenueUploads          ActualRevenueEntry[]
  stageAssumptionUpdates  StageAssumption[]
}

// ─── CRM Entities ─────────────────────────────────────────────────────────────

enum DealStage {
  first_convo
  opp_qual
  stakeholder
  verbal
  contracting
  closed_won
  lost
}

enum DealSource {
  conference
  referral
  organic_inbound
  paid_inbound
  email_outbound
  linkedin
  other
  unknown
}

enum DealType {
  new_logo
  expansion
  renewal
  lost_keep_warm
}

enum ProductLine {
  acp
  kidney
  chf
  oncology
}

enum PaymentStructure {
  enterprise
  pmpm
  success_fee
}

enum DealStatus {
  active
  won
  lost
  stalled
}

enum CompanyStage {
  unaware
  aware
  engaged
  opportunity
  customer
  evangelist
}

enum SalesType {
  vbc_enabler
  health_system
  payor
  aco
  ffs
  payvider
}

enum BudgetCycle {
  Q1
  Q2
  Q3
  Q4
}

model Company {
  id                String        @id
  name              String
  salesType         SalesType?
  companyStage      CompanyStage?
  icpTier           Int?
  icpFitScore       Float?
  patientPopulation Int?
  budgetCycle       BudgetCycle?
  attioCreatedAt    DateTime?
  attioUpdatedAt    DateTime?
  lastSyncedAt      DateTime?
  deals             Deal[]
}

model Deal {
  id                     String            @id
  name                   String
  companyId              String?
  value                  Decimal?          @db.Decimal(12, 2)
  stage                  DealStage?
  source                 DealSource?
  typeOfDeal             DealType?
  productLine            ProductLine?
  paymentStructure       PaymentStructure?
  status                 DealStatus        @default(active)
  stageEnteredAt         DateTime?
  firstConvoDate         DateTime?
  expectedClosedDate     DateTime?
  closedWonDate          DateTime?
  closedLostDate         DateTime?
  implementationFeeValue Decimal?          @db.Decimal(12, 2)
  integrationFeeValue    Decimal?          @db.Decimal(12, 2)
  attioCreatedAt         DateTime?
  attioUpdatedAt         DateTime?
  lastSyncedAt           DateTime?
  company                Company?          @relation(fields: [companyId], references: [id])
  revenueEntries         ActualRevenueEntry[]

  @@index([companyId])
  @@index([stage])
  @@index([status])
}

// ─── Pipeline Snapshots ───────────────────────────────────────────────────────

model PipelineSnapshot {
  id               String   @id @default(uuid())
  capturedAt       DateTime @default(now())
  pipelineTotal    Decimal  @db.Decimal(12, 2)
  weightedForecast Decimal  @db.Decimal(12, 2)
  activeDealCount  Int
  avgDealSize      Decimal  @db.Decimal(12, 2)
  stageBreakdown   Json
  sourceBreakdown  Json
  companyBreakdown Json
  typeBreakdown    Json

  @@index([capturedAt])
}

// ─── Actual Revenue (QuickBooks uploads) ──────────────────────────────────────

enum MatchStatus {
  matched
  unmatched
  non_deal
}

model ActualRevenueEntry {
  id            String      @id @default(uuid())
  uploadBatchId String
  periodStart   DateTime
  periodEnd     DateTime
  customerName  String
  dealId        String?
  amount        Decimal     @db.Decimal(12, 2)
  matchStatus   MatchStatus @default(unmatched)
  uploadedAt    DateTime    @default(now())
  uploadedById  String
  uploadedBy    User        @relation(fields: [uploadedById], references: [id])
  deal          Deal?       @relation(fields: [dealId], references: [id])

  @@index([dealId])
  @@index([uploadedById])
  @@index([uploadBatchId])
}

// ─── Stage Assumptions ────────────────────────────────────────────────────────

model StageAssumption {
  stage            DealStage @id
  overallCloseRate Float
  conversionToNext Float
  avgDaysInStage   Int
  updatedAt        DateTime  @updatedAt
  updatedById      String?
  updatedBy        User?     @relation(fields: [updatedById], references: [id])
}

// ─── Fiscal Config ────────────────────────────────────────────────────────────

model FiscalConfig {
  fiscalYear           Int      @id
  revenueGoal          Decimal  @db.Decimal(12, 2)
  existingArr          Decimal  @db.Decimal(12, 2)
  expectedFromExisting Decimal  @db.Decimal(12, 2)
  fiscalYearStart      DateTime
  fiscalYearEnd        DateTime
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

enum AuditAction {
  SYNC_ATTIO
  SYNC_SHEETS
  SNAPSHOT_CREATED
  ASSUMPTION_EDITED
  REVENUE_UPLOADED
  REVENUE_MATCHED
  USER_INVITED
  USER_ROLE_CHANGED
  FISCAL_CONFIG_UPDATED
}

model AuditLog {
  id        String      @id @default(uuid())
  action    AuditAction
  userId    String?
  details   Json?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
}
